# 1. Palindrome check
def is_palindrome(s):
    return s == s[::-1]

# 2. Two Sum
def two_sum(nums, target):
    seen = {}
    for i, n in enumerate(nums):
        if target - n in seen:
            return [seen[target - n], i]
        seen[n] = i
    return []

# 3. Find duplicates
def find_duplicates(lst):
    seen, dupes = set(), set()
    for x in lst:
        if x in seen:
            dupes.add(x)
        seen.add(x)
    return list(dupes)


# 4. Word frequency
def word_freq(sentence):
    words = sentence.split()
    freq = {}
    for w in words:
        freq[w] = freq.get(w, 0) + 1
    return freq

# 5. Reverse string without slicing
def reverse_str(s):
    result = ""
    for ch in s:
        result = ch + result
    return result
